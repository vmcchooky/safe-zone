SAFE_ZONE_ENV=local
SAFE_ZONE_DEPLOYMENT_TIER=budget-vps
SAFE_ZONE_DOCKER_LOG_MAX_SIZE=10m
SAFE_ZONE_DOCKER_LOG_MAX_FILE=5

# --- Production Edge (Caddy + DuckDNS) ---
SAFE_ZONE_PUBLIC_HOST=safezone.example.com
SAFE_ZONE_CADDY_EMAIL=admin@example.com
SAFE_ZONE_DUCKDNS_DOMAIN=
SAFE_ZONE_DUCKDNS_TOKEN=
SAFE_ZONE_DUCKDNS_TOKEN_FILE=
# For local files and Compose containers, prefer paths under ./ops/secrets
# and set either VAR or VAR_FILE, not both.
SAFE_ZONE_SECRET_FILE_ROOT=./ops/secrets
SAFE_ZONE_FEED_FILE_ROOT=./data
SAFE_ZONE_CONFIG_FILE_ROOT=./data

SAFE_ZONE_HEALTHCHECK_PORT=8080
SAFE_ZONE_HEALTHCHECK_PATH=/healthz

SAFE_ZONE_CORE_API_ADDR=:8080
SAFE_ZONE_DNS_RESOLVER_ADDR=:8081
SAFE_ZONE_SHUTDOWN_TIMEOUT_MS=10000

SAFE_ZONE_REDIS_ADDR=redis:6379
SAFE_ZONE_REDIS_PASSWORD=
SAFE_ZONE_REDIS_PASSWORD_FILE=
SAFE_ZONE_REDIS_DB=0
SAFE_ZONE_REDIS_TIMEOUT_MS=250
SAFE_ZONE_REDIS_MAXMEMORY=256mb

SAFE_ZONE_THREAT_FEED_KEY=safe-zone:threat:feed
SAFE_ZONE_THREAT_FEED_SOURCE=
SAFE_ZONE_FEED_SYNC_TIMEOUT_MS=30000
SAFE_ZONE_FEED_MAX_BYTES=52428800
SAFE_ZONE_FEED_SYNC_INTERVAL_SECONDS=86400
SAFE_ZONE_FEED_DRIFT_INVALID_RATIO=0.20
SAFE_ZONE_FEED_DRIFT_MIN_INVALID=25
SAFE_ZONE_FEED_CACHE_INVALIDATION_MIN_WRITES=1
# --- AI Provider Configuration ---
# Options: none (disabled), gemini (free cloud), ollama (local offline), hybrid (ollama with gemini fallback)
# Note: "gemini" is perfect for low-RAM VPS (< 2GB RAM), while "ollama" is ideal for full offline privacy.
SAFE_ZONE_AI_PROVIDER=gemini

# Google Gemini API Settings (Cloud AI)
SAFE_ZONE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
SAFE_ZONE_GEMINI_API_KEY=
SAFE_ZONE_GEMINI_API_KEY_FILE=
SAFE_ZONE_GEMINI_MODEL=gemini-2.5-flash-lite
SAFE_ZONE_GEMINI_TIMEOUT_MS=3000

# Local Ollama Settings (Offline AI)
SAFE_ZONE_OLLAMA_BASE_URL=http://localhost:11434
SAFE_ZONE_OLLAMA_MODEL=gemma2:2b
SAFE_ZONE_OLLAMA_TIMEOUT_MS=5000

SAFE_ZONE_CACHE_TTL_ALLOWED_SECONDS=10800
SAFE_ZONE_CACHE_TTL_SUSPICIOUS_SECONDS=3600
SAFE_ZONE_CACHE_TTL_BLOCKED_SECONDS=21600

SAFE_ZONE_UPSTREAM_DOH_URL=https://cloudflare-dns.com/dns-query
SAFE_ZONE_UPSTREAM_DOH_TIMEOUT_MS=3000
SAFE_ZONE_BLOCK_PAGE_IP=127.0.0.1
# In production, set SAFE_ZONE_BLOCK_PAGE_IP to the public IPv4 that serves the
# Safe Zone block page. Keep 127.0.0.1 for local development only.
SAFE_ZONE_DNS_BLOCK_TTL_SECONDS=60
SAFE_ZONE_BLOCK_PAGE_SUPPORT_EMAIL=
SAFE_ZONE_ENRICH_ENABLED=true
SAFE_ZONE_ENRICH_TIMEOUT_MS=3000

# --- OSINT Public Evidence Lookup ---
# Uses configured public warning/feed pages first; optional paid API keys can be
# wired later without changing /v1/analyze.
SAFE_ZONE_OSINT_ENABLED=true
SAFE_ZONE_OSINT_MODE=background_on_demand
SAFE_ZONE_OSINT_TIMEOUT_MS=2000
SAFE_ZONE_OSINT_CACHE_TTL_SECONDS=21600
SAFE_ZONE_OSINT_TRUSTED_DOMAINS=gov.vn,bocongan.gov.vn,mps.gov.vn,baochinhphu.vn,thanhnien.vn,tuoitre.vn,vnexpress.net,vietnamnet.vn,nhandan.vn,vtv.vn,vov.vn
# Comma-separated URLs for official/free warning pages, RSS feeds, or curated
# public alert pages. Do not use Google HTML scraping; use official APIs if added.
SAFE_ZONE_OSINT_SOURCES=

SAFE_ZONE_DASHBOARD_RECENT_LIMIT=25

# --- SQLite (Telemetry & Local Overrides) ---
SAFE_ZONE_SQLITE_PATH=/run/safe-zone/data/safe-zone.db
SAFE_ZONE_TELEMETRY_RETENTION_DAYS=30

# --- Rate Limiting ---
SAFE_ZONE_RATELIMIT_ENABLED=true
SAFE_ZONE_RATELIMIT_ANALYZE_RPM=10
SAFE_ZONE_RATELIMIT_ANALYZE_BURST=5
SAFE_ZONE_RATELIMIT_OVERRIDE_RPM=20
SAFE_ZONE_RATELIMIT_OVERRIDE_BURST=5
SAFE_ZONE_RATELIMIT_TELEMETRY_RPM=30
SAFE_ZONE_RATELIMIT_TELEMETRY_BURST=10
SAFE_ZONE_RATELIMIT_DOH_RPM=100
SAFE_ZONE_RATELIMIT_DOH_BURST=20
SAFE_ZONE_RATELIMIT_DEFAULT_RPM=60
SAFE_ZONE_RATELIMIT_DEFAULT_BURST=15

# --- AI Agent Workflow ---
SAFE_ZONE_AGENT_ENABLED=false
SAFE_ZONE_AGENT_AUDIT_INTERVAL_SECONDS=3600
SAFE_ZONE_AGENT_AUDIT_TIMEOUT_SECONDS=300
SAFE_ZONE_AGENT_AUDIT_MIN_OCCURRENCES=3
SAFE_ZONE_AGENT_AUDIT_MAX_PER_CYCLE=50
SAFE_ZONE_AGENT_AUDIT_CONFIDENCE_THRESHOLD=0.7
SAFE_ZONE_AGENT_ENRICH_TIMEOUT_SECONDS=5
SAFE_ZONE_AGENT_FEED_PRESET=
# Set SAFE_ZONE_AGENT_FEED_PRESET=production-free to use the built-in free preset:
# - https://urlhaus.abuse.ch/downloads/csv_recent/
# - https://raw.githubusercontent.com/openphish/public_feed/refs/heads/main/feed.txt
# REScure currently shows a temporary-closure page as of 2026-05-21, so it is not part
# of the first-class preset anymore.
SAFE_ZONE_AGENT_FEED_SOURCES=
SAFE_ZONE_AGENT_FEED_INTERVAL_SECONDS=86400
SAFE_ZONE_AGENT_FEED_TIMEOUT_SECONDS=120
SAFE_ZONE_AGENT_FEED_STALE_AFTER_SECONDS=129600
SAFE_ZONE_AGENT_FEED_DRIFT_INVALID_RATIO=0.20
SAFE_ZONE_AGENT_FEED_DRIFT_MIN_INVALID=25
SAFE_ZONE_AGENT_FEED_CACHE_INVALIDATION_MIN_WRITES=1
SAFE_ZONE_AGENT_OSINT_INTERVAL_SECONDS=3600
SAFE_ZONE_AGENT_OSINT_TIMEOUT_SECONDS=120
SAFE_ZONE_AGENT_OSINT_MAX_PER_CYCLE=50
SAFE_ZONE_AGENT_OSINT_LOOKBACK_SECONDS=86400
SAFE_ZONE_AGENT_WEBHOOK_URL=
SAFE_ZONE_AGENT_WEBHOOK_URL_FILE=
SAFE_ZONE_AGENT_ALERT_INTERVAL_SECONDS=900
SAFE_ZONE_AGENT_ALERT_TIMEOUT_SECONDS=30
SAFE_ZONE_AGENT_ALERT_MIN_EVENTS=1

# --- Whitelist Auto-Update ---
SAFE_ZONE_AGENT_WHITELIST_ENABLED=true
SAFE_ZONE_AGENT_WHITELIST_INTERVAL_SECONDS=604800
SAFE_ZONE_AGENT_WHITELIST_TIMEOUT_SECONDS=600
SAFE_ZONE_AGENT_WHITELIST_SOURCE_URL=https://tranco-list.eu/download/L/1000000

# --- DNS-over-TLS (DoT) Configurations ---
SAFE_ZONE_DNS_DOT_ENABLED=true
SAFE_ZONE_DNS_DOT_CONTAINER_PORT=8533
SAFE_ZONE_DNS_DOT_PUBLISHED_PORT=853
SAFE_ZONE_DNS_DOT_DEV_PUBLISHED_PORT=1853
SAFE_ZONE_DNS_DOT_CERTS_DIR=./ops/certs/dot
SAFE_ZONE_DNS_DOT_CERT_FILE=
SAFE_ZONE_DNS_DOT_KEY_FILE=
SAFE_ZONE_RATELIMIT_DOT_RPM=100
SAFE_ZONE_RATELIMIT_DOT_BURST=20

# --- Admin Security ---
SAFE_ZONE_ADMIN_PASSWORD=
SAFE_ZONE_ADMIN_PASSWORD_FILE=
SAFE_ZONE_ADMIN_API_KEY=
SAFE_ZONE_ADMIN_API_KEY_FILE=

# --- Advanced Alert Settings ---
# Telegram Configuration
SAFE_ZONE_ALERT_TELEGRAM_ENABLED=false
SAFE_ZONE_ALERT_TELEGRAM_TOKEN=your_bot_token_here
SAFE_ZONE_ALERT_TELEGRAM_TOKEN_FILE=
SAFE_ZONE_ALERT_TELEGRAM_CHAT_ID=your_chat_id_here

# Slack Configuration
SAFE_ZONE_ALERT_SLACK_ENABLED=false
SAFE_ZONE_ALERT_SLACK_WEBHOOK_URL=your_slack_webhook_url_here
SAFE_ZONE_ALERT_SLACK_WEBHOOK_URL_FILE=

# Email Configuration
SAFE_ZONE_ALERT_EMAIL_ENABLED=false
SAFE_ZONE_ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
SAFE_ZONE_ALERT_EMAIL_SMTP_PORT=587
SAFE_ZONE_ALERT_EMAIL_USERNAME=
SAFE_ZONE_ALERT_EMAIL_FROM=sender@gmail.com
SAFE_ZONE_ALERT_EMAIL_PASSWORD=your_app_password
SAFE_ZONE_ALERT_EMAIL_PASSWORD_FILE=
SAFE_ZONE_ALERT_EMAIL_TO=admin@example.com

# --- Offsite Backups (rclone) ---
SAFE_ZONE_RCLONE_REMOTE=
SAFE_ZONE_RCLONE_DEST=safe-zone-backups

# --- DNS Blocking Strategy ---
# Options:
# - sinkhole: Resolve A/AAAA to SAFE_ZONE_BLOCK_PAGE_IP (allows HTTP block page, but causes HTTPS SSL warnings)
# - nxdomain: Return NXDOMAIN error (silent blocking, avoids HTTPS SSL warnings)
# - refused: Return REFUSED DNS error
# - nullip: Resolve A to 0.0.0.0 and AAAA to :: (instant fails, avoids HTTPS SSL warnings)
SAFE_ZONE_DNS_BLOCK_STRATEGY=sinkhole
