SAFE_ZONE_ENV=production
SAFE_ZONE_DEPLOYMENT_TIER=production-edge-staging
SAFE_ZONE_PUBLIC_HOST=safe-staging.quorix.io.vn
SAFE_ZONE_CADDY_EMAIL=admin@quorix.io.vn

# Staging uses production behavior with staging-only secrets and hostnames.
SAFE_ZONE_ADMIN_PASSWORD=replace-with-staging-password
SAFE_ZONE_ADMIN_API_KEY=replace-with-staging-64-char-random-hex

SAFE_ZONE_AI_PROVIDER=none
SAFE_ZONE_DNS_DOT_ENABLED=false

SAFE_ZONE_REDIS_ADDR=redis:6379
SAFE_ZONE_REDIS_MAXMEMORY=256mb

SAFE_ZONE_BLOCK_PAGE_IP=replace-with-staging-vps-public-ip
SAFE_ZONE_BLOCK_PAGE_SUPPORT_EMAIL=security-staging@quorix.io.vn
SAFE_ZONE_DNS_BLOCK_STRATEGY=sinkhole

SAFE_ZONE_AGENT_ENABLED=false
SAFE_ZONE_AGENT_FEED_PRESET=
SAFE_ZONE_AGENT_FEED_SOURCES=

SAFE_ZONE_DOCKER_LOG_MAX_SIZE=10m
SAFE_ZONE_DOCKER_LOG_MAX_FILE=5
